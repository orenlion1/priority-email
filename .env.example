# Copy to .env for local development. Do not commit .env.

AWS_REGION=us-east-1
AWS_PROFILE=
AWS_ACCOUNT_ID=

# Email providers
GMAIL_GOOGLE_CLOUD_PROJECT_ID=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKENS=
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
YAHOO_REFRESH_TOKENS=
YAHOO_REDIRECT_URI=
YAHOO_EMAIL=
YAHOO_APP_PASSWORD=
YAHOO_IMAP_HOST=imap.mail.yahoo.com
YAHOO_IMAP_PORT=993
ICLOUD_ACCOUNTS=

# Slack
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Push notifications
PUSH_PROVIDER=aws-end-user-messaging-push
PUSH_APPLICATION_ID=
PUSH_PROVIDER_TOKEN=
PUSH_CHANNELS_ENABLED=

# DynamoDB
DYNAMODB_PROCESSED_MESSAGES_TABLE=priority-email-processed-messages
DYNAMODB_CHECKPOINTS_TABLE=priority-email-checkpoints

# Grafana Cloud / OpenTelemetry
GRAFANA_CLOUD_OTLP_ENDPOINT=
GRAFANA_CLOUD_INSTANCE_ID=
GRAFANA_CLOUD_API_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=priority-email-service
OTEL_SERVICE_NAMESPACE=priority-email
OTEL_DEPLOYMENT_ENVIRONMENT=production
OTEL_EXPORTER_OTLP_TIMEOUT_SECONDS=5

# Poller
EMAIL_POLL_ENABLED_PROVIDERS=gmail
EMAIL_POLL_INTERVAL_SECONDS=600
EMAIL_POLL_INITIAL_MAX_MESSAGES=20
EMAIL_POLL_MAX_MESSAGES=50
EMAIL_POLL_STATE_FILE=.state/email-poller-state.json
EMAIL_POLL_LOG_FILE=.state/email-poller.log
EMAIL_POLL_SLACK_ERROR_NOTIFICATIONS_ENABLED=true
